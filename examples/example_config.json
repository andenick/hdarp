{
  "_comment": "Example HDARP configuration. Pass this to PDFSplitterOrchestrator and HDARPOrchestrator constructors.",

  "splitter": {
    "max_chunk_size_mb": 1.0,
    "max_chunk_pages": 10,
    "create_manifest": true,
    "low_density_threshold": 0.05,
    "high_density_threshold": 0.10
  },

  "ocr": {
    "engines": ["paddleocr", "easyocr", "tesseract"],
    "paddleocr": {
      "lang": "en"
    },
    "easyocr": {
      "languages": ["en"],
      "gpu": false
    },
    "consensus": {
      "high_confidence_threshold": 0.95,
      "low_confidence_threshold": 0.50,
      "similarity_threshold": 0.80,
      "engine_priority": {
        "paddle": 3,
        "easyocr": 2,
        "tesseract": 1
      }
    }
  },

  "quality": {
    "minimum_grade": "B",
    "flag_below_score": 20
  },

  "orchestrator": {
    "batch_size": 10,
    "auto_continue": true,
    "single_batch": false
  }
}
